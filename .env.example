# Database (auto-set by Electron in production)
DATABASE_URL="file:./qorpera.db"

# AI Provider — configure one
AI_PROVIDER=ollama
# AI_PROVIDER=openai
# AI_PROVIDER=anthropic

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
