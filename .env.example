# ===========================================
# Qorpera Configuration
# ===========================================

# --- Database ---
DATABASE_URL=postgresql://qorpera:qorpera_secret@localhost:5432/qorpera

# --- Security ---
# Generate with: openssl rand -base64 48
ENCRYPTION_SECRET=change-me-to-a-random-string-at-least-32-chars

# --- AI Provider ---
# Options: openai, anthropic, ollama
AI_PROVIDER=openai
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o

# --- Embedding (optional — defaults to AI provider settings) ---
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-your-key-here
# EMBEDDING_MODEL=text-embedding-3-small

# --- Document Storage ---
DOCUMENT_STORAGE_PATH=/data/documents

# --- Connector OAuth (optional — only needed for specific connectors) ---
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# STRIPE_CLIENT_ID=
# STRIPE_SECRET_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Superadmin ---
SUPERADMIN_EMAIL=jonas@qorpera.com
SUPERADMIN_PASSWORD=  # Set a strong password

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
