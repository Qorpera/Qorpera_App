# ===========================================
# Qorpera Configuration
# ===========================================

# ─── Database ───────────────────────────────────────────
# For development (persistent data — your real Qorpera operator):
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
#
# For testing (disposable — docker compose uses local Postgres by default):
# DATABASE_URL=postgresql://qorpera:qorpera_secret@localhost:5432/qorpera
DATABASE_URL=

# --- Security ---
# Generate with: openssl rand -base64 48
ENCRYPTION_SECRET=change-me-to-a-random-string-at-least-32-chars

# --- AI Provider ---
# Options: openai, anthropic, ollama
AI_PROVIDER=openai
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o

# --- Embedding (optional — defaults to AI provider settings) ---
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-your-key-here
# EMBEDDING_MODEL=text-embedding-3-small

# --- Document Storage ---
DOCUMENT_STORAGE_PATH=/data/documents

# --- Connector OAuth (optional — only needed for specific connectors) ---
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# STRIPE_CLIENT_ID=
# STRIPE_SECRET_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Superadmin ---
SUPERADMIN_EMAIL=jonas@qorpera.com
SUPERADMIN_PASSWORD=  # Set a strong password

# --- Registration ---
REGISTRATION_ENABLED=false  # Set to "true" to allow new operator registration

# --- Cron ---
# Cron job authentication (set to a random string, used in Vercel cron config)
CRON_SECRET=

# --- Sentry (optional — errors logged to console without it) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=       # build-time only, for source map upload
SENTRY_ORG=
SENTRY_PROJECT=

# --- Upstash Redis (optional — falls back to in-memory rate limiting without it) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
