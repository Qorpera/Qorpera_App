{
  "name": "qorpera-app",
  "version": "0.1.0",
  "private": true,
  "description": "Qorpera — Governed AI Workflow Engine",
  "author": {
    "name": "Qorpera",
    "email": "hello@qorpera.com"
  },
  "homepage": "https://qorpera.com",
  "main": "electron/main.js",
  "scripts": {
    "dev": "tsx electron/dev-server.ts",
    "dev:next": "next dev",
    "build:next": "next build",
    "build": "npm run build:next && npm run build:stage && tsc -p tsconfig.electron.json && electron-builder",
    "build:stage": "rm -rf _standalone && cp -r .next/standalone _standalone && cp -r .next/static _standalone/.next/static && mv _standalone/node_modules _standalone/deps",
    "setup": "prisma db push && tsx src/lib/seed.ts",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "migrate-chunks": "npx tsx scripts/migrate-document-chunks.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@sentry/nextjs": "^10.45.0",
    "@types/archiver": "^7.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "cron-parser": "^5.5.0",
    "docx": "^9.6.1",
    "mammoth": "^1.11.0",
    "next": "^14.2.29",
    "openai": "^6.32.0",
    "papaparse": "^5.5.2",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.3",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
