{
  "buildCommand": "npm run build",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/activity-absence",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/send-digest",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/follow-ups",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/recurring-tasks",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/initiatives",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/insights",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/priorities",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/process-deletions",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/billing-rampup",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/recover-stuck-agents",
      "schedule": "*/5 * * * *"
    }
  ]
}
