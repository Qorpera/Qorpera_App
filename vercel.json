{
  "buildCommand": "npm run build",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/activity-absence",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/send-digest",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/follow-ups",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/process-deletions",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/reevaluate-chunks",
      "schedule": "30 4 * * *"
    }
  ]
}
