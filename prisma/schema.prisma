// Prisma schema for QorperaAPP — SQLite local database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Core ────────────────────────────────────────────────

model Operator {
  id           String   @id @default(cuid())
  displayName  String
  email        String?
  passwordHash String?
  createdAt    DateTime @default(now())

  entityTypes       OemEntityType[]
  entities          OemEntity[]
  relationshipTypes OemRelationshipType[]
  connectors        SourceConnector[]
  policyRules       PolicyRule[]
  actionRules       ActionRule[]
  proposals         ActionProposal[]
  auditEntries      AuditEntry[]
  recommendations   Recommendation[]
  importJobs        ImportJob[]
  workflows         Workflow[]
  governanceConfig  GovernanceConfig?
}

model AppSetting {
  key   String @id
  value String
}

// ─── Layer 3: Operational Entity Model ───────────────────

model OemEntityType {
  id          String @id @default(cuid())
  operatorId  String
  name        String
  slug        String
  description String @default("")
  icon        String @default("box")
  color       String @default("#a855f7")

  operator    Operator            @relation(fields: [operatorId], references: [id])
  properties  OemEntityProperty[]
  entities    OemEntity[]
  fromLinks   OemRelationshipType[] @relation("FromType")
  toLinks     OemRelationshipType[] @relation("ToType")

  @@unique([operatorId, slug])
}

model OemEntityProperty {
  id           String  @id @default(cuid())
  entityTypeId String
  name         String
  slug         String
  dataType     String  @default("STRING") // STRING, NUMBER, DATE, BOOLEAN, ENUM, CURRENCY
  required     Boolean @default(false)
  filterable   Boolean @default(false)
  displayOrder Int     @default(0)
  enumValues   String? // JSON array for ENUM type
  identityRole String? // email, domain, phone

  entityType OemEntityType          @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)
  values     OemEntityPropertyValue[]

  @@unique([entityTypeId, slug])
}

model OemEntity {
  id           String   @id @default(cuid())
  entityTypeId String
  operatorId   String
  displayName  String
  status       String   @default("active") // active, archived, merged
  sourceSystem String?
  externalId   String?
  mergedIntoId String?
  metadata     String?  // JSON
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entityType    OemEntityType          @relation(fields: [entityTypeId], references: [id])
  operator      Operator               @relation(fields: [operatorId], references: [id])
  mergedInto    OemEntity?             @relation("MergedEntities", fields: [mergedIntoId], references: [id])
  mergedFrom    OemEntity[]            @relation("MergedEntities")
  propertyValues OemEntityPropertyValue[]
  mentions       OemEntityMention[]
  fromRelations  OemEntityRelationship[] @relation("FromEntity")
  toRelations    OemEntityRelationship[] @relation("ToEntity")
  proposals      ActionProposal[]
  recommendations Recommendation[]
}

model OemEntityPropertyValue {
  id         String @id @default(cuid())
  entityId   String
  propertyId String
  value      String

  entity   OemEntity         @relation(fields: [entityId], references: [id], onDelete: Cascade)
  property OemEntityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([entityId, propertyId])
}

model OemEntityMention {
  id         String   @id @default(cuid())
  entityId   String
  sourceType String
  sourceId   String
  snippet    String?
  createdAt  DateTime @default(now())

  entity OemEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

// ─── Relationships ───────────────────────────────────────

model OemRelationshipType {
  id              String @id @default(cuid())
  operatorId      String
  name            String
  slug            String
  fromEntityTypeId String
  toEntityTypeId   String
  description     String @default("")

  operator Operator    @relation(fields: [operatorId], references: [id])
  fromType OemEntityType @relation("FromType", fields: [fromEntityTypeId], references: [id])
  toType   OemEntityType @relation("ToType", fields: [toEntityTypeId], references: [id])
  relationships OemEntityRelationship[]

  @@unique([operatorId, slug])
}

model OemEntityRelationship {
  id                 String   @id @default(cuid())
  relationshipTypeId String
  fromEntityId       String
  toEntityId         String
  metadata           String?  // JSON
  createdAt          DateTime @default(now())

  relationshipType OemRelationshipType @relation(fields: [relationshipTypeId], references: [id])
  fromEntity       OemEntity           @relation("FromEntity", fields: [fromEntityId], references: [id])
  toEntity         OemEntity           @relation("ToEntity", fields: [toEntityId], references: [id])

  @@unique([relationshipTypeId, fromEntityId, toEntityId])
}

// ─── Source Connectors & Sync ────────────────────────────

model SourceConnector {
  id         String   @id @default(cuid())
  operatorId String
  provider   String   // csv, json, api
  status     String   @default("active")
  config     String?  // JSON
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())

  operator Operator  @relation(fields: [operatorId], references: [id])
  syncLogs SyncLog[]
}

model SyncLog {
  id              String   @id @default(cuid())
  connectorId     String
  status          String   // success, partial, failed
  entitiesCreated Int      @default(0)
  entitiesUpdated Int      @default(0)
  errors          String?  // JSON
  createdAt       DateTime @default(now())

  connector SourceConnector @relation(fields: [connectorId], references: [id])
}

// ─── Layer 4: Policy & Action ────────────────────────────

model PolicyRule {
  id            String  @id @default(cuid())
  operatorId    String
  name          String
  scope         String  // global, entity_type, entity
  scopeTargetId String?
  actionType    String  // create, update, delete, approve, execute
  effect        String  // ALLOW, DENY, REQUIRE_APPROVAL
  conditions    String? // JSON
  priority      Int     @default(0)
  enabled       Boolean @default(true)
  createdAt     DateTime @default(now())

  operator Operator     @relation(fields: [operatorId], references: [id])
  auditEntries AuditEntry[]
}

model ActionRule {
  id              String    @id @default(cuid())
  operatorId      String
  name            String
  description     String    @default("")
  entityTypeSlug  String
  triggerOn       String    @default("mutation") // "mutation" | "tick"
  conditions      String    @default("[]")       // JSON: [{field, operator, value}]
  actionType      String                         // "create_proposal" | "update_entity" | "flag_for_review" | "send_notification"
  actionConfig    String    @default("{}")        // JSON: action-specific params
  priority        Int       @default(0)
  enabled         Boolean   @default(true)
  lastEvaluatedAt DateTime?
  createdAt       DateTime  @default(now())

  operator Operator @relation(fields: [operatorId], references: [id])
}

model ActionProposal {
  id             String    @id @default(cuid())
  operatorId     String
  actionType     String
  description    String
  entityId       String?
  entityTypeSlug String?
  sourceAgent    String?
  inputData      String?   // JSON
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  reviewedBy     String?
  reviewNote     String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?

  operator Operator     @relation(fields: [operatorId], references: [id])
  entity   OemEntity?   @relation(fields: [entityId], references: [id])
  auditEntries AuditEntry[]
}

// ─── Layer 5: Audit ──────────────────────────────────────

model AuditEntry {
  id             String   @id @default(cuid())
  operatorId     String
  action         String
  actorType      String   @default("operator") // operator, system, ai
  actorId        String?
  entityId       String?
  entityTypeSlug String?
  inputSnapshot  String?  // JSON
  outputSnapshot String?  // JSON
  policyRuleId   String?
  proposalId     String?
  outcome        String   @default("success") // success, denied, pending_approval
  duration       Int?     // ms
  createdAt      DateTime @default(now())

  operator   Operator        @relation(fields: [operatorId], references: [id])
  policyRule PolicyRule?     @relation(fields: [policyRuleId], references: [id])
  proposal   ActionProposal? @relation(fields: [proposalId], references: [id])
}

// ─── Governance Config ───────────────────────────────────

model GovernanceConfig {
  id                        String  @id @default(cuid())
  operatorId                String  @unique
  requireApprovalAboveAmount Float?
  autoApproveReadActions    Boolean @default(true)
  maxPendingProposals       Int     @default(50)
  approvalExpiryHours       Int     @default(72)

  operator Operator @relation(fields: [operatorId], references: [id])
}

// ─── Layer 6: Intelligence ───────────────────────────────

model Recommendation {
  id             String   @id @default(cuid())
  operatorId     String
  title          String
  description    String
  reasoning      String?
  actionType     String?
  entityId       String?
  entityTypeSlug String?
  confidence     Float    @default(0.5)
  priority       String   @default("medium") // low, medium, high, critical
  status         String   @default("active") // active, accepted, dismissed, expired
  createdAt      DateTime @default(now())

  operator Operator   @relation(fields: [operatorId], references: [id])
  entity   OemEntity? @relation(fields: [entityId], references: [id])
}

// ─── Data Import ─────────────────────────────────────────

model ImportJob {
  id            String   @id @default(cuid())
  operatorId    String
  fileName      String
  fileType      String   // csv, json
  targetTypeSlug String?
  status        String   @default("pending") // pending, mapping, processing, completed, failed
  rowsTotal     Int      @default(0)
  rowsProcessed Int      @default(0)
  rowsSkipped   Int      @default(0)
  errors        String?  // JSON
  columnMapping String?  // JSON
  rawData       String?  // stored CSV/JSON content
  createdAt     DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id])
}

// ─── Workflows ───────────────────────────────────────────

model Workflow {
  id          String    @id @default(cuid())
  operatorId  String
  name        String
  description String    @default("")
  triggerType String    @default("manual") // manual, schedule, event
  graph       String?   // JSON: nodes + edges
  status      String    @default("draft") // draft, active, paused
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())

  operator Operator      @relation(fields: [operatorId], references: [id])
  runs     WorkflowRun[]
}

model WorkflowRun {
  id          String    @id @default(cuid())
  workflowId  String
  status      String    @default("running") // running, completed, failed
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  result      String?   // JSON

  workflow Workflow @relation(fields: [workflowId], references: [id])
}
