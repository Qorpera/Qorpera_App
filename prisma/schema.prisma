// Prisma schema for Qorpera — PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Billing ────────────────────────────────────────────────

enum BillingStatus {
  free
  active
  depleted
  past_due
  cancelled
}

model CreditTransaction {
  id                    String   @id @default(cuid())
  operatorId            String
  operator              Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  type                  String // 'purchase' | 'auto_reload' | 'situation_deduction' | 'copilot_deduction' | 'adjustment'
  amountCents           Int // positive for credits added, negative for deductions
  balanceAfter          Int // balance snapshot after this transaction
  description           String?
  stripePaymentIntentId String?
  situationId           String?
  copilotMessageId      String?
  createdAt             DateTime @default(now())

  @@index([operatorId, createdAt])
}

// ─── Core ────────────────────────────────────────────────

model Operator {
  id              String   @id @default(cuid())
  displayName     String
  email           String?
  passwordHash    String?
  companyName     String?
  companyDomain   String? // e.g. "qorpera.com" — extracted from admin email at registration
  industry        String?
  isTestOperator  Boolean  @default(false)
  aiResponseStore Boolean  @default(false)
  createdAt       DateTime @default(now())

  // Stripe
  stripeCustomerId String?       @unique
  billingStatus    BillingStatus @default(free)
  billingStartedAt DateTime?

  // Prepaid credit balance
  balanceCents             Int     @default(0)
  autoReloadEnabled        Boolean @default(false)
  autoReloadThresholdCents Int     @default(500)
  autoReloadAmountCents    Int     @default(2500)
  stripePaymentMethodId    String?

  // Pricing (computed on the fly, kept for compatibility)
  orchestrationFeeMultiplier Float @default(0.50)

  // Free tier caps
  freeCopilotBudgetCents      Int       @default(500)
  freeCopilotUsedCents        Int       @default(0)
  freeDetectionStartedAt      DateTime?
  freeDetectionSituationCount Int       @default(0)

  // Intelligence network
  intelligenceAccess Boolean @default(false) // true = can read system wiki pages

  // Emergency stop
  aiPaused       Boolean   @default(false)
  aiPausedAt     DateTime?
  aiPausedById   String?
  aiPausedReason String?

  // Usage budget (Limits page)
  monthlyBudgetCents         Int?
  budgetAlertThresholds      Json?
  budgetHardStop             Boolean   @default(false)
  budgetAlertsSentThisPeriod Json?
  budgetPeriodStart          DateTime?

  invites              Invite[]
  entityTypes          EntityType[]
  entities             Entity[]
  relationshipTypes    RelationshipType[]
  connectors           SourceConnector[]
  slackChannelMappings SlackChannelMapping[]
  policyRules          PolicyRule[]
  // v2: Situation-driven architecture
  events               Event[]
  situationTypes       SituationType[]
  situations           Situation[]
  orientationSessions  OrientationSession[]
  copilotMessages      CopilotMessage[]
  actionCapabilities   ActionCapability[]
  notifications        Notification[]
  users                User[]
  internalDocuments    InternalDocument[]
  contentChunks        ContentChunk[]
  activitySignals      ActivitySignal[]
  entityMergeLogs      EntityMergeLog[]
  personalAutonomies   PersonalAutonomy[]
  initiatives          Initiative[]
  executionPlans       ExecutionPlan[]
  workStreams          WorkStream[]
  delegations          Delegation[]
  followUps            FollowUp[]
  recurringTasks       RecurringTask[]
  planAutonomies       PlanAutonomy[]
  operationalInsights  OperationalInsight[]
  systemJobs           SystemJob[]
  systemJobRuns        SystemJobRun[]
  priorityOverrides    PriorityOverride[]
  appSettings          AppSetting[]
  onboardingAnalysis   OnboardingAnalysis?
  creditTransactions   CreditTransaction[]
  domainHealth         DomainHealth[]
  // v4: Projects
  projectTemplates     ProjectTemplate[]
  projects             Project[]
  // v5: Wiki knowledge
  knowledgePages       KnowledgePage[]
  evidenceExtractions  EvidenceExtraction[]
  correlationFindings  CorrelationFinding[]
  // v6: File uploads
  storageUsedBytes     BigInt                @default(0)
  storageLimitBytes    BigInt                @default(10737418240) // 10 GB
  fileUploads          FileUpload[]
  wikiBookmarks        WikiBookmark[]
  researchPlans        ResearchPlan[]
  contextEvaluations   ContextEvaluation[]
  systemIntelligenceSignals SystemIntelligenceSignal[]

  // Org invite link
  inviteToken          String?   @unique
  inviteTokenCreatedAt DateTime?

  // Deletion lifecycle (GDPR)
  deletionRequestedAt     DateTime?
  deletionScheduledFor    DateTime?
  foundationalDocStatuses FoundationalDocStatus[]
}

model User {
  id               String    @id @default(cuid())
  operatorId       String
  operator         Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  email            String    @unique
  name             String
  passwordHash     String
  role             String    @default("member") // "superadmin" | "admin" | "member"
  entityId         String?   @unique // FK to Entity — the base entity this user represents in the org chart
  entity           Entity?   @relation(fields: [entityId], references: [id], onDelete: SetNull)
  locale           String    @default("en")
  emailVerified    Boolean   @default(false)
  emailVerifiedAt  DateTime?
  lastDigestSentAt DateTime?
  digestEnabled    Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions                      Session[]
  scopes                        UserScope[]
  invitesCreated                Invite[]                 @relation("InviteCreator")
  connectors                    SourceConnector[]
  aiEntity                      Entity?                  @relation("AiEntity")
  notificationPreferences       NotificationPreference[]
  priorityOverrides             PriorityOverride[]
  passwordResetTokens           PasswordResetToken[]
  contentChunks                 ContentChunk[]
  situationViews                SituationView[]
  // v4: Projects
  createdProjects               Project[]                @relation("ProjectCreator")
  projectMemberships            ProjectMember[]          @relation("ProjectMemberUser")
  projectMembersAdded           ProjectMember[]          @relation("ProjectMemberAddedBy")
  projectMessages               ProjectMessage[]
  projectChatMessages           ProjectChatMessage[]
  projectDeliverableAssignments ProjectDeliverable[]     @relation("DeliverableAssignee")
  projectDeliverableAcceptances ProjectDeliverable[]     @relation("DeliverableAcceptor")
  fileUploads                   FileUpload[]             @relation("UserFileUploads")

  // Deletion / suspension (for content privacy lifecycle)
  deletionRequestedAt  DateTime?
  deletionScheduledFor DateTime?
  accountSuspended     Boolean   @default(false)

  @@index([operatorId])
  @@index([entityId])
}

model AppSetting {
  id               String    @id @default(cuid())
  key              String
  value            String
  operatorId       String?
  lastModifiedById String?
  lastModifiedAt   DateTime?
  operator         Operator? @relation(fields: [operatorId], references: [id])

  @@unique([key, operatorId])
}

// ─── Auth ────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// ─── Layer 2: Knowledge Graph Engine ─────────────────────

model EntityType {
  id          String @id @default(cuid())
  operatorId  String
  name        String
  slug        String
  description String @default("")
  icon        String @default("box")
  color       String @default("#a855f7")

  operator   Operator           @relation(fields: [operatorId], references: [id])
  properties EntityProperty[]
  entities   Entity[]
  fromLinks  RelationshipType[] @relation("FromType")
  toLinks    RelationshipType[] @relation("ToType")

  defaultCategory String @default("digital")

  @@unique([operatorId, slug])
}

model EntityProperty {
  id           String  @id @default(cuid())
  entityTypeId String
  name         String
  slug         String
  dataType     String  @default("STRING") // STRING, NUMBER, DATE, BOOLEAN, ENUM, CURRENCY
  required     Boolean @default(false)
  filterable   Boolean @default(false)
  displayOrder Int     @default(0)
  enumValues   String? // JSON array for ENUM type
  identityRole String? // email, domain, phone

  entityType EntityType      @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)
  values     PropertyValue[]

  @@unique([entityTypeId, slug])
}

model Entity {
  id                 String   @id @default(cuid())
  entityTypeId       String
  operatorId         String
  displayName        String
  status             String   @default("active") // active, archived, merged
  category           String   @default("digital")
  // Values: "foundational" | "base" | "internal" | "digital" | "external"
  sourceSystem       String?
  externalId         String?
  mergedIntoId       String?
  metadata           String? // JSON
  description        String? // Domain purpose one-liner
  mapX               Float? // For foundational entities: position on 2D map
  mapY               Float?
  primaryDomainId    String?  @map("parentDepartmentId")
  ownerUserId        String?  @unique // Only set on ai-agent entities — links to the owning User
  ownerDomainId      String?  @unique @map("ownerDepartmentId") // Only set on domain-ai entities
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  entityType           EntityType            @relation(fields: [entityTypeId], references: [id])
  operator             Operator              @relation(fields: [operatorId], references: [id])
  mergedInto           Entity?               @relation("MergedEntities", fields: [mergedIntoId], references: [id])
  mergedFrom           Entity[]              @relation("MergedEntities")
  primaryDomain        Entity?               @relation("DomainMembers", fields: [primaryDomainId], references: [id])
  domainMembers        Entity[]              @relation("DomainMembers")
  propertyValues       PropertyValue[]
  mentions             EntityMention[]
  slackChannelMappings SlackChannelMapping[]
  fromRelations        Relationship[]        @relation("FromEntity")
  toRelations          Relationship[]        @relation("ToEntity")
  internalDocument     InternalDocument?     @relation("DocumentEntity")
  user                 User? // A base entity can have at most one user account
  ownerUser            User?                 @relation("AiEntity", fields: [ownerUserId], references: [id], onDelete: SetNull)
  personalAutonomies   PersonalAutonomy[]
  systemJobsAsDomain   SystemJob[]           @relation("SystemJobDomain")
  systemJobsAsAssignee SystemJob[]           @relation("SystemJobAssignee")

  @@index([operatorId, category])
  @@index([operatorId, primaryDomainId])
  @@index([ownerUserId])
}

model PropertyValue {
  id         String @id @default(cuid())
  entityId   String
  propertyId String
  value      String

  entity   Entity         @relation(fields: [entityId], references: [id], onDelete: Cascade)
  property EntityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([entityId, propertyId])
  @@index([propertyId, value])
}

model EntityMention {
  id         String   @id @default(cuid())
  entityId   String
  sourceType String
  sourceId   String
  snippet    String?
  createdAt  DateTime @default(now())

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

// ─── Relationships ───────────────────────────────────────

model RelationshipType {
  id               String @id @default(cuid())
  operatorId       String
  name             String
  slug             String
  fromEntityTypeId String
  toEntityTypeId   String
  description      String @default("")

  operator      Operator       @relation(fields: [operatorId], references: [id])
  fromType      EntityType     @relation("FromType", fields: [fromEntityTypeId], references: [id])
  toType        EntityType     @relation("ToType", fields: [toEntityTypeId], references: [id])
  relationships Relationship[]

  @@unique([operatorId, slug])
}

model Relationship {
  id                 String   @id @default(cuid())
  relationshipTypeId String
  fromEntityId       String
  toEntityId         String
  metadata           String? // JSON
  createdAt          DateTime @default(now())

  relationshipType RelationshipType @relation(fields: [relationshipTypeId], references: [id])
  fromEntity       Entity           @relation("FromEntity", fields: [fromEntityId], references: [id])
  toEntity         Entity           @relation("ToEntity", fields: [toEntityId], references: [id])

  @@unique([relationshipTypeId, fromEntityId, toEntityId])
  @@index([fromEntityId])
  @@index([toEntityId])
}

// ─── Source Connectors & Sync ────────────────────────────

model SourceConnector {
  id                  String    @id @default(cuid())
  operatorId          String
  userId              String?
  provider            String // "google", "hubspot", "stripe"
  name                String    @default("") // user-facing label
  status              String    @default("active") // active, paused, error, disconnected, pending
  config              String? // JSON - provider-specific config
  lastSyncAt          DateTime?
  consecutiveFailures Int       @default(0)
  createdAt           DateTime  @default(now())

  // Soft delete
  deletedAt   DateTime?
  deletedById String?

  // Health tracking
  healthStatus    String    @default("healthy") // healthy | degraded | error | disconnected
  lastHealthCheck DateTime?
  lastError       String?

  materializerConfig String? // JSON: dynamic materializer rules from ontology inference

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  operator             Operator              @relation(fields: [operatorId], references: [id])
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  events               Event[]
  syncLogs             SyncLog[]
  actionCapabilities   ActionCapability[]
  contentChunks        ContentChunk[]
  slackChannelMappings SlackChannelMapping[]
  projectConnectors    ProjectConnector[]

  @@index([projectId])
}

model SlackChannelMapping {
  id           String   @id @default(cuid())
  operatorId   String
  connectorId  String
  channelId    String // Slack channel ID (e.g., "C012345")
  channelName  String // Display name (e.g., "#general")
  domainId   String   @map("departmentId") // Entity ID of the domain (category = "foundational")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  operator  Operator        @relation(fields: [operatorId], references: [id])
  connector SourceConnector @relation(fields: [connectorId], references: [id])
  domain    Entity          @relation(fields: [domainId], references: [id])

  @@unique([connectorId, channelId])
  @@index([operatorId])
  @@index([connectorId])
}

model SyncLog {
  id            String   @id @default(cuid())
  connectorId   String
  status        String // success, partial, failed
  eventsCreated Int      @default(0)
  eventsSkipped Int      @default(0)
  errors        String? // JSON
  durationMs    Int? // how long the sync took
  diagnostics   String? // JSON: post-sync quality metrics
  createdAt     DateTime @default(now())

  connector SourceConnector @relation(fields: [connectorId], references: [id])
}

// ─── Layer 4: Policy & Action ────────────────────────────

model PolicyRule {
  id               String    @id @default(cuid())
  operatorId       String
  name             String
  scope            String // global, entity_type, entity
  scopeTargetId    String?
  actionType       String // create, update, delete, approve, execute
  effect           String // ALLOW, DENY, REQUIRE_APPROVAL
  conditions       String? // JSON
  priority         Int       @default(0)
  enabled          Boolean   @default(true)
  lastModifiedById String?
  lastModifiedAt   DateTime?
  createdAt        DateTime  @default(now())

  operator Operator @relation(fields: [operatorId], references: [id])
}

// ─── Layer 1: Event Stream ───────────────────────────

model Event {
  id                   String    @id @default(cuid())
  operatorId           String
  connectorId          String? // links event to its source connector (null for manual/system events)
  source               String // "hubspot", "stripe", "gmail", "sheets", "manual"
  eventType            String // "contact.synced", "invoice.created", "row.synced"
  payload              String // JSON - raw event data from the source
  entityRefs           String? // JSON - resolved entity IDs (populated by materializer)
  processedAt          DateTime?
  materializationError String? // Error message if materialization failed (enables retry)
  createdAt            DateTime  @default(now())

  operator   Operator         @relation(fields: [operatorId], references: [id])
  connector  SourceConnector? @relation(fields: [connectorId], references: [id])
  situations SituationEvent[]

  @@index([operatorId, createdAt(sort: Desc)])
  @@index([operatorId, source, eventType])
  @@index([operatorId, processedAt])
  @@index([connectorId, createdAt(sort: Desc)])
}

// ─── Situation Archetypes ────────────────────────────

model SituationArchetype {
  slug              String   @id // "overdue_invoice", "client_escalation", etc.
  name              String // Human-readable: "Overdue Invoice"
  description       String // Used in LLM classification prompt
  category          String // "payment_financial", "sales_pipeline", "client_communication", "people_hr", "operations_delivery", "knowledge_governance"
  detectionTemplate String? // JSON — default detectionLogic for auto-created types
  defaultSeverity   String   @default("medium") // "low" | "medium" | "high"
  examplePhrases    String? // JSON array of 3-5 example trigger descriptions for classification
  createdAt         DateTime @default(now())
}

// ─── Layer 3: Situations ─────────────────────────────

model SituationType {
  id                   String    @id @default(cuid())
  operatorId           String
  slug                 String
  name                 String
  description          String // natural language description from orientation
  detectionLogic       String // JSON - signals, thresholds, patterns
  responseStrategy     String? // JSON - default response template
  autonomyLevel        String    @default("supervised") // supervised, notify, autonomous
  approvalRate         Float     @default(0) // rolling approval rate
  totalProposed        Int       @default(0)
  totalApproved        Int       @default(0)
  consecutiveApprovals Int       @default(0)
  scopeEntityId        String? // anchor entity for scoped detection
  scopeDepth           Int? // max hops from anchor (default: unlimited within subtree)
  enabled              Boolean   @default(true)
  archetypeSlug        String? // Maps to SituationArchetype.slug — null for custom/unclassified types
  visibleToRoles       String? // JSON array of role strings
  preFilterPassCount   Int       @default(0)
  llmConfirmCount      Int       @default(0)
  auditMissCount       Int       @default(0)
  lastAuditAt          DateTime?
  detectedCount        Int       @default(0)
  confirmedCount       Int       @default(0)
  dismissedCount       Int       @default(0)
  promptVersion        Int       @default(1) // Reserved for post-launch reasoning prompt optimization canary system
  lastModifiedById     String?
  lastModifiedAt       DateTime?
  createdAt            DateTime  @default(now())

  operator           Operator           @relation(fields: [operatorId], references: [id])
  situations         Situation[]
  personalAutonomies PersonalAutonomy[]

  @@unique([operatorId, slug])
}

model Situation {
  id              String @id @default(cuid())
  operatorId      String
  situationTypeId String
  severity        Float  @default(0.5) // 0-1
  confidence      Float  @default(0.5) // 0-1
  source          String @default("detected") // detected, retrospective, manual
  status          String @default("detected")
  // detected → reasoning → proposed → approved → executing → monitoring → resolved
  // monitoring: all current cycle steps complete, waiting for external signal to trigger next cycle
  // detected → reasoning → proposed → rejected → closed
  // detected → auto_executing → resolved (autonomous mode)

  // Context snapshot at detection time
  contextSnapshot String? // JSON - entities, events, priors
  triggerEvidence String? // JSON - the raw evidence that caused detection
  triggerSummary  String? // Human-readable 1-2 sentence headline
  resumeSummary   String? // Haiku-generated cumulative situation briefing (only for 2+ cycle situations)
  triggerEntityId String? // the primary entity this situation is about
  triggerEventId  String?
  assignedUserId  String?

  // AI reasoning
  investigationDepth String  @default("standard") // "standard" | "thorough"
  analysisDocument   Json? // ContentDoc JSON — thorough analysis for deep situations
  reasoning          String? // JSON - analysis, considered actions, justification
  proposedAction     String? // JSON - { batch, afterBatch, reEvaluationReason, monitorDurationHours }
  afterBatch         String? // "resolve" | "re_evaluate" | "monitor"
  monitorUntil       DateTime? // for "monitor" — when to trigger re-evaluation

  // Outcome tracking
  actionTaken      String? // JSON - what actually happened
  outcome          String? // positive, negative, neutral, unknown
  outcomeDetails   String? // JSON
  feedback         String? // human feedback text
  feedbackRating   Int? // 1-5
  feedbackCategory String? // "detection_wrong", "action_wrong", "timing_wrong", "missing_context"
  editInstruction  String? // freeform text from Edit & Approve flow

  // LLM tracking
  modelId             String? // LLM model string used for reasoning (e.g., "gpt-4o", "claude-sonnet-4-20250514")
  promptVersion       Int? // reasoning prompt version number at time of reasoning
  reasoningDurationMs Int? // wall-clock time of the reasoning LLM call in milliseconds

  // Billing
  apiCostCents Int? // Actual API cost in cents for reasoning
  billedCents  Int? // Amount billed to customer
  billedAt     DateTime?

  resolvedAt      DateTime?
  executionPlanId String?   @unique
  delegationId    String?   @unique
  spawningStepId  String? // ExecutionStep.id that spawned this situation (not FK — avoids circular deps)
  createdAt       DateTime  @default(now())

  operator       Operator         @relation(fields: [operatorId], references: [id])
  situationType  SituationType    @relation(fields: [situationTypeId], references: [id])
  events         SituationEvent[]
  executionPlan  ExecutionPlan?   @relation(fields: [executionPlanId], references: [id])
  delegation     Delegation?      @relation(fields: [delegationId], references: [id], onDelete: SetNull)
  cycles         SituationCycle[]
  views              SituationView[]
  toolCallTraces     ToolCallTrace[]
  contextEvaluations ContextEvaluation[]

  @@index([operatorId, status])
  @@index([situationTypeId, createdAt(sort: Desc)])
  @@index([situationTypeId, triggerEntityId])
}

model SituationEvent {
  situationId String
  eventId     String

  situation Situation @relation(fields: [situationId], references: [id])
  event     Event     @relation(fields: [eventId], references: [id])

  @@id([situationId, eventId])
}

model SituationView {
  id          String   @id @default(cuid())
  userId      String
  situationId String
  viewedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  situation Situation @relation(fields: [situationId], references: [id], onDelete: Cascade)

  @@unique([userId, situationId])
  @@index([userId])
}

// ─── Orientation / Onboarding ────────────────────────

model OrientationSession {
  id          String    @id @default(cuid())
  operatorId  String
  phase       String    @default("mapping") // mapping, populating, connecting, syncing, orienting, active
  context     String? // JSON - accumulated business understanding
  messages    String? // JSON - conversation history
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  operator Operator @relation(fields: [operatorId], references: [id])
}

// ─── Copilot Memory ──────────────────────────────────

model CopilotMessage {
  id           String   @id @default(cuid())
  operatorId   String
  userId       String?
  sessionId    String
  role         String // user, assistant, tool, system
  content      String
  apiCostCents Int? // Actual API cost for this message's LLM call
  createdAt    DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id])

  @@index([operatorId, sessionId, createdAt])
}

// ─── Action Capabilities ─────────────────────────────

model ActionCapability {
  id               String    @id @default(cuid())
  operatorId       String
  connectorId      String?
  slug             String? // write capability identifier (from provider.writeCapabilities)
  name             String // "send_email", "create_invoice", "update_crm_field"
  description      String
  inputSchema      String? // JSON schema
  sideEffects      String? // JSON - what happens when this runs
  reversible       Boolean   @default(false)
  enabled          Boolean   @default(true)
  writeBackStatus  String    @default("pending") // "pending" | "enabled" | "disabled"
  nudgeDismissedAt DateTime?

  operator  Operator         @relation(fields: [operatorId], references: [id])
  connector SourceConnector? @relation(fields: [connectorId], references: [id])
}

// ─── Notifications ───────────────────────────────────

model Notification {
  id               String   @id @default(cuid())
  operatorId       String
  userId           String?
  title            String
  body             String
  read             Boolean  @default(false)
  sourceType       String? // situation, system, orientation
  sourceId         String?
  sourceAiEntityId String?
  createdAt        DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id])

  @@index([operatorId, read, createdAt(sort: Desc)])
}

// ─── Internal Documents ──────────────────────────────────

model InternalDocument {
  id                String   @id @default(cuid())
  operatorId        String
  operator          Operator @relation(fields: [operatorId], references: [id])
  fileName          String
  mimeType          String
  filePath          String
  rawText           String?
  status            String   @default("uploaded") // uploaded, processing, extracted, confirmed
  extractedEntities String? // JSON: { entities: [...], relationships: [...], businessContext: string }
  businessContext   String?
  entityId          String?  @unique
  entity            Entity?  @relation("DocumentEntity", fields: [entityId], references: [id])
  documentType      String   @default("context") // "org-chart" | "budget" | "compensation" | "team-roster" | "context"
  embeddingStatus   String   @default("pending") // "pending" | "processing" | "complete" | "error"
  domainId          String?  @map("departmentId")
  projectId         String?
  project           Project? @relation(fields: [projectId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([operatorId, domainId])
  @@index([entityId])
}

// ─── Invites ────────────────────────────────────────────

model Invite {
  id              String    @id @default(cuid())
  operatorId      String
  operator        Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  entityId        String // The base entity this invite is for
  email           String // Pre-filled from entity or entered by admin
  role            String    @default("member")
  passwordHash    String // Admin sets the password
  token           String    @unique
  expiresAt       DateTime
  claimedAt       DateTime?
  claimedByUserId String?
  createdById     String? // The admin who created this invite (nullable if admin deleted)
  createdBy       User?     @relation("InviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())

  @@index([token])
  @@index([operatorId])
  @@index([entityId])
}

model UserScope {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domainEntityId     String   @map("departmentEntityId") // FK to Entity (a foundational/domain entity)
  grantedById        String? // userId of who granted this — null for system-generated
  createdAt          DateTime @default(now())

  @@unique([userId, domainEntityId])
  @@index([userId])
  @@index([domainEntityId])
}

// ─── Content Chunks (universal RAG store) ───────────────

model ContentChunk {
  id                   String    @id @default(cuid())
  operatorId           String
  connectorId          String?
  userId               String?
  sourceType           String // "email" | "slack_message" | "drive_doc" | "uploaded_doc" | "calendar_note"
  sourceId             String // reference to origin (Event.id, InternalDocument.id, etc.)
  entityId             String? // entity this content is about (if resolvable)
  domainIds            String? @map("departmentIds") // JSON array of domain IDs (derived from participant routing)
  chunkIndex           Int
  content              String
  embedding            String? // actually vector(1536) — see raw SQL migration
  tokenCount           Int?
  metadata             String? // JSON: { subject, sender, timestamp, channel, fileName, etc. }
  classifiedAt         DateTime?
  classificationMethod String? // "algorithmic" | "llm" | "operator_wide"
  reevaluatedAt        DateTime?
  documentCategory     String? // "foundational" | "operational" | null
  foundationalDocSlug  String? // Links to ExpectedDocument.slug
  projectId            String?
  createdAt            DateTime  @default(now())

  wikiProcessedAt DateTime?

  operator            Operator             @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  connector           SourceConnector?     @relation(fields: [connectorId], references: [id])
  user                User?                @relation(fields: [userId], references: [id])
  project             Project?             @relation(fields: [projectId], references: [id])
  evidenceExtractions EvidenceExtraction[]
  fileUploadId        String?
  fileUpload          FileUpload?          @relation(fields: [fileUploadId], references: [id])

  @@index([operatorId, sourceType])
  @@index([entityId])
  @@index([operatorId, sourceId])
  @@index([connectorId])
  @@index([operatorId, userId])
  @@index([operatorId, classifiedAt])
  @@index([operatorId, projectId])
}

// ─── Evidence Registry ──────────────────────────────────

model EvidenceExtraction {
  id             String       @id @default(cuid())
  operatorId     String
  operator       Operator     @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  sourceChunkId  String
  sourceChunk    ContentChunk @relation(fields: [sourceChunkId], references: [id], onDelete: Cascade)
  sourceType     String // "email", "document", "financial", "calendar", "slack", "crm", "hr"
  extractions    Json // Array<EvidenceClaim>
  relationships  Json // Array<EvidenceRelationship>
  contradictions Json // Array<EvidenceContradiction>
  extractedBy    String // model identifier that performed extraction
  extractedAt    DateTime     @default(now())
  documentContext     Json?      // { documentType, sectionTitle, authorIntent, relevantRedFlags }
  analyticalClaims    Json?      // Array<{ claim, type, derivedFrom, expertiseBasis, confidence, reasoning }>
  correlationId       String?    // Links extractions to a CorrelationFinding batch
  createdAt      DateTime     @default(now())

  @@index([operatorId])
  @@index([sourceChunkId])
  @@index([operatorId, sourceType])
}

model CorrelationFinding {
  id                  String   @id @default(cuid())
  operatorId          String
  operator            Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  type                String   // "confirmation" | "contradiction" | "gap" | "implication" | "pattern"
  finding             String
  significance        String   // "critical" | "significant" | "minor"
  confidence          Float
  primarySourceId     String   // EvidenceExtraction ID or ContentChunk ID
  correlatedSourceIds String[] @default([])
  implications        String?
  resolvedInWikiSlug  String?  // Wiki page that addresses this finding
  createdAt           DateTime @default(now())

  @@index([operatorId])
  @@index([operatorId, type])
  @@index([operatorId, significance])
}

model AnalysisPromptVersion {
  id              String    @id @default(cuid())
  promptType      String    // "comprehension" | "extraction" | "correlation" | "synthesis"
  version         Int
  content         String    // Full prompt text
  parentVersionId String?   // What version this mutated from
  mutation        String?   // What was changed and why

  // Quality metrics (populated asynchronously)
  pagesProduced   Int       @default(0)
  compositeScore  Float?
  citationRate    Float?
  approvalRate    Float?
  analyticalDepth Float?    // ratio of analytical to raw claims

  status          String    @default("active") // "active" | "testing" | "retired" | "reverted"
  deployedAt      DateTime?
  retiredAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([promptType, status])
  @@unique([promptType, version])
}

// ─── Activity Signals ───────────────────────────────────

model ActivitySignal {
  id              String    @id @default(cuid())
  operatorId      String
  connectorId     String?
  signalType      String // "email_sent" | "email_received" | "slack_message" | "doc_edit" | "meeting_held" | "doc_created" | "doc_shared"
  actorEntityId   String? // who did it (resolved to entity if possible)
  targetEntityIds String? // JSON array — who/what was it about
  domainIds       String? @map("departmentIds") // JSON array — derived from participant routing
  metadata        String? // JSON: { response_time_ms, thread_id, channel, file_name, attendees, etc. }
  occurredAt      DateTime // when the activity happened (not when we ingested it)
  wikiProcessedAt DateTime?
  createdAt       DateTime  @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId, signalType, occurredAt(sort: Desc)])
  @@index([operatorId, actorEntityId, occurredAt(sort: Desc)])
  @@index([operatorId, occurredAt(sort: Desc)])
}

// ─── Entity Merge Log ───────────────────────────────────

model EntityMergeLog {
  id         String    @id @default(cuid())
  operatorId String
  survivorId String // entity that absorbed the other
  absorbedId String // entity that was merged into survivor
  mergeType  String // "auto_identity" | "ml_high_confidence" | "admin_manual"
  confidence Float? // ML confidence score (null for deterministic merges)
  signals    String? // JSON: what triggered the merge
  snapshot   String? // JSON: full state of absorbed entity before merge, for reversal
  reversible Boolean   @default(true)
  reversedAt DateTime?
  createdAt  DateTime  @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId, createdAt(sort: Desc)])
  @@index([operatorId, mergeType])
}

// ─── Personal AI Autonomy ───────────────────────────────

model PersonalAutonomy {
  id                   String    @id @default(cuid())
  operatorId           String
  situationTypeId      String
  aiEntityId           String
  autonomyLevel        String    @default("supervised") // supervised, notify, autonomous
  consecutiveApprovals Int       @default(0)
  totalProposed        Int       @default(0)
  totalApproved        Int       @default(0)
  approvalRate         Float     @default(0)
  promotedAt           DateTime?
  promotedById         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  operator      Operator      @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  situationType SituationType @relation(fields: [situationTypeId], references: [id])
  aiEntity      Entity        @relation(fields: [aiEntityId], references: [id])

  @@unique([situationTypeId, aiEntityId])
  @@index([operatorId])
  @@index([aiEntityId])
}

// ─── Initiatives & Execution ────────────────────────────

model Initiative {
  id               String   @id @default(cuid())
  operatorId       String
  aiEntityId       String // the domain-ai or hq-ai that proposed this
  proposalType     String // "project_creation" | "policy_change" | "autonomy_graduation" | "system_job_creation" | "strategy_revision" | "wiki_update" | "resource_recommendation" | "general"
  triggerSummary   String // one-line description of what was detected
  evidence         Json? // array of {source: string, claim: string} showing what triggered this
  proposal         Json   // the actual work product — varies by proposalType
  status           String   @default("proposed") // proposed, approved, executing, completed, rejected, failed, paused
  rationale        String
  impactAssessment String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  proposedProjectConfig Json? // @deprecated — reads from proposal for project_creation type, kept for backward compat
  projectId             String? @unique

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id])

  resolvedBookmarks WikiBookmark[]

  @@index([operatorId, status])
}

model ExecutionPlan {
  id                     String    @id @default(cuid())
  operatorId             String
  sourceType             String // "situation" | "initiative" | "recurring" | "delegation"
  sourceId               String // ID of the source record
  status                 String    @default("pending") // pending, approved, executing, completed, failed, paused, amended
  currentStepOrder       Int       @default(1)
  approvedAt             DateTime?
  approvedById           String?
  completedAt            DateTime?
  priorityScore          Float?
  modelId                String? // LLM model string used for plan reasoning
  promptVersion          Int? // reasoning prompt version at time of plan creation
  totalStepExecutions    Int       @default(0) // counter incremented on every step execution attempt
  maxStepExecutions      Int       @default(15) // hard ceiling; plan fails if exceeded
  modifiedBeforeApproval Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  operator         Operator          @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  steps            ExecutionStep[]
  situation        Situation?
  cycle            SituationCycle?
  priorityOverride PriorityOverride?

  @@index([operatorId, status])
  @@index([operatorId, sourceType, sourceId])
}

model ExecutionStep {
  id                  String    @id @default(cuid())
  planId              String
  sequenceOrder       Int
  title               String
  description         String
  executionMode       String // "action" | "generate" | "human_task"
  actionCapabilityId  String?
  assignedUserId      String?
  parameters          String? // JSON — structured action parameters for preview UI
  inputContext        String? // JSON
  outputResult        String? // JSON — typed StepOutput
  status              String    @default("pending") // pending, awaiting_approval, approved, executing, completed, failed, skipped, amended, awaiting_situation
  approvedAt          DateTime?
  approvedById        String?
  executedAt          DateTime?
  errorMessage        String?
  originalDescription String? // preserved when amended
  apiCostCents        Int? // Actual API cost for this step's LLM call
  retryCount          Int       @default(0)
  lastError           String?
  createdAt           DateTime  @default(now())

  plan     ExecutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  followUp FollowUp?

  @@unique([planId, sequenceOrder])
  @@index([planId, status])
}

model WorkStream {
  id                     String    @id @default(cuid())
  operatorId             String
  title                  String
  description            String?
  ownerAiEntityId        String?
  status                 String    @default("active") // active, completed, paused, abandoned
  parentWorkStreamId     String?
  lastReassessmentAt     DateTime?
  lastReassessmentResult String? // JSON
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  completedAt            DateTime?

  operator         Operator         @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  parentWorkStream WorkStream?      @relation("WorkStreamChildren", fields: [parentWorkStreamId], references: [id])
  children         WorkStream[]     @relation("WorkStreamChildren")
  items            WorkStreamItem[]

  @@index([operatorId, status])
}

model WorkStreamItem {
  id           String   @id @default(cuid())
  workStreamId String
  itemType     String // "situation" | "initiative"
  itemId       String
  addedAt      DateTime @default(now())

  workStream WorkStream @relation(fields: [workStreamId], references: [id], onDelete: Cascade)

  @@unique([workStreamId, itemType, itemId])
}

model Delegation {
  id             String    @id @default(cuid())
  operatorId     String
  fromAiEntityId String
  toAiEntityId   String?
  toUserId       String?
  workStreamId   String?
  situationId    String?
  initiativeId   String?
  instruction    String
  context        String? // JSON
  status         String    @default("pending") // pending, accepted, completed, returned
  returnReason   String?
  completedNotes String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  operator  Operator   @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  situation Situation?

  @@index([operatorId, status])
  @@index([toUserId, status])
  @@index([toAiEntityId, status])
}

model FollowUp {
  id               String    @id @default(cuid())
  operatorId       String
  executionStepId  String    @unique
  situationId      String?
  triggerCondition String // JSON: { type: "timeout" | "response_received" | "property_change", ... }
  fallbackAction   String // JSON: { type: "escalate" | "new_plan" | "notify" | "skip", ... }
  status           String    @default("watching") // watching, triggered, expired, cancelled
  triggerAt        DateTime?
  reminderSent     Boolean   @default(false)
  createdAt        DateTime  @default(now())
  triggeredAt      DateTime?

  operator      Operator      @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  executionStep ExecutionStep @relation(fields: [executionStepId], references: [id], onDelete: Cascade)

  @@index([operatorId, status])
  @@index([status, triggerAt])
}

model RecurringTask {
  id                    String    @id @default(cuid())
  operatorId            String
  aiEntityId            String
  title                 String
  description           String?
  cronExpression        String
  executionPlanTemplate String // JSON — template for plan creation
  lastTriggeredAt       DateTime?
  nextTriggerAt         DateTime?
  autoApproveSteps      Boolean   @default(false)
  status                String    @default("active") // active, paused
  createdAt             DateTime  @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId, status])
  @@index([status, nextTriggerAt])
}

model SystemJob {
  id                   String    @id @default(cuid())
  operatorId           String
  aiEntityId           String
  title                String
  description          String   @db.Text // natural language description of what this job monitors and investigates
  cronExpression       String
  domainEntityId       String   // REQUIRED — which domain this job monitors
  assigneeEntityId     String?  // Optional specific person; if null, domain operators receive findings
  scope                String    @default("domain") // domain | cross_domain | personal | company_wide
  scopeEntityId        String? // Legacy — kept for backward compat, prefer domainEntityId
  archetypeSlug        String? // Links to system job archetype for cross-org learning
  status               String    @default("proposed") // proposed | active | paused | deactivated
  source               String    @default("manual") // initiative | strategic_scan | onboarding | manual | self_amendment
  importanceThreshold  Float     @default(0.3)
  autoDispatchFindings Boolean   @default(false) // For graduated trust — auto-create situations/initiatives
  consecutiveApprovals Int       @default(0) // Trust gradient tracking
  lastTriggeredAt      DateTime?
  nextTriggerAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  operator    Operator       @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  domain      Entity         @relation("SystemJobDomain", fields: [domainEntityId], references: [id])
  assignee    Entity?        @relation("SystemJobAssignee", fields: [assigneeEntityId], references: [id])
  runs        SystemJobRun[]

  @@index([operatorId, status])
  @@index([status, nextTriggerAt])
  @@index([domainEntityId])
}

model SystemJobRun {
  id                      String   @id @default(cuid())
  systemJobId             String
  operatorId              String
  cycleNumber             Int
  status                  String   @default("running") // running | completed | failed | compressed
  importanceScore         Float?
  summary                 String?
  analysisNarrative       String?  @db.Text
  findings                Json? // Array of { title, description, category }
  proposedSituationCount  Int      @default(0)
  proposedInitiativeCount Int      @default(0)
  selfAmendments          Json? // Array of { type, description, rationale }
  cycleComparison         Json? // { keyChanges[], priorRecommendationOutcomes[] }
  rawReasoning            String?  @db.Text // Full LLM output for debugging
  tokenCost               Float?
  durationMs              Int?
  errorMessage            String?
  createdAt               DateTime @default(now())

  systemJob SystemJob @relation(fields: [systemJobId], references: [id], onDelete: Cascade)
  operator  Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([systemJobId, cycleNumber])
  @@index([operatorId, createdAt])
}

model PlanAutonomy {
  id                   String   @id @default(cuid())
  operatorId           String
  aiEntityId           String
  planPatternHash      String // SHA256 of step titles+modes
  consecutiveApprovals Int      @default(0)
  autoApproved         Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([aiEntityId, planPatternHash])
  @@index([operatorId])
}

model OperationalInsight {
  id                 String   @id @default(cuid())
  operatorId         String
  aiEntityId         String
  domainId           String?  @map("departmentId")
  insightType        String // approach_effectiveness, timing_pattern, entity_preference, escalation_pattern, resolution_pattern
  description        String
  evidence           String // JSON: { sampleSize, successRate, situations[], ... }
  confidence         Float
  promptModification String?
  shareScope         String   @default("personal") // personal, department (legacy), operator
  status             String   @default("active") // active, superseded, invalidated
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId, shareScope, status])
  @@index([aiEntityId, status])
  @@index([operatorId, domainId, status])
}

model NotificationPreference {
  id               String @id @default(cuid())
  userId           String
  notificationType String // situation_proposed, situation_resolved, initiative_proposed, step_ready, delegation_received, follow_up_triggered, plan_auto_executed, peer_signal, insight_discovered, system_alert
  channel          String @default("both") // in_app, email, both, none

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationType])
  @@index([userId])
}

model PriorityOverride {
  id              String        @id @default(dbgenerated("gen_random_uuid()"))
  operatorId      String
  executionPlanId String        @unique
  overrideType    String // "pin" | "snooze"
  snoozeUntil     DateTime?
  createdById     String
  createdAt       DateTime      @default(now())
  operator        Operator      @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  executionPlan   ExecutionPlan @relation(fields: [executionPlanId], references: [id], onDelete: Cascade)
  createdBy       User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

// ─── Onboarding Intelligence ────────────────────────────

model OnboardingAnalysis {
  id           String   @id @default(cuid())
  operatorId   String
  operator     Operator @relation(fields: [operatorId], references: [id])
  status       String   @default("pending") // pending, syncing, analyzing, confirming, complete, failed
  currentPhase String   @default("idle") // idle, round_0, round_1, organizer_1, round_2, organizer_2, round_3, synthesis

  // Progress reporting (polled by UI)
  progressMessages Json @default("[]") // Array of { timestamp, message, agentName? }

  // Synthesis output
  synthesisOutput Json? // Complete company model JSON
  uncertaintyLog  Json? // Questions the system couldn't resolve

  // Tracking
  totalTokensUsed Int       @default(0)
  totalCostCents  Int       @default(0)
  modelOverride   String? // If set, pipeline uses this model instead of MODEL_ROUTES.onboardingAgent
  startedAt       DateTime?
  completedAt     DateTime?
  workerClaimedAt DateTime? // When worker picked up the job
  notifiedAt      DateTime? // When "analysis complete" email was sent
  failureReason   String?

  // Relations
  agentRuns OnboardingAgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operatorId]) // One analysis per operator (restart = delete + recreate)
  @@index([status])
}

model OnboardingAgentRun {
  id         String             @id @default(cuid())
  analysisId String
  analysis   OnboardingAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  agentName String // temporal_analyst, org_analyst, process_analyst, relationship_analyst, knowledge_analyst, financial_analyst, organizer
  round     Int    @default(1) // 0, 1, 2, 3

  status         String @default("pending") // pending, running, paused, complete, failed
  iterationCount Int    @default(0)
  maxIterations  Int    @default(30) // Safety cap per agent

  // Working memory — compact summary of findings so far (kept small for context window)
  workingMemory Json @default("{}") // { findings: string, hypotheses: string[], openQuestions: string[], investigationPlan: string }

  // Organizer input
  followUpBrief Json? // Cross-pollination brief from Organizer

  // Final output
  report Json? // Agent's completed report

  // Tool call audit log
  toolCallLog Json @default("[]") // Array of { tool, args, resultSummary, durationMs, timestamp }

  // Timing
  tokensUsed      Int       @default(0)
  costCents       Int       @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  lastIterationAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([analysisId, agentName, round])
  @@index([analysisId, status])
}

// ─── System Health ───────────────────────────────────────

model DomainHealth {
  id               String   @id @default(cuid())
  operatorId       String
  domainEntityId   String?  @map("departmentEntityId") // null = operator-level aggregate
  snapshot         Json
  computedAt       DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([operatorId, domainEntityId])
  @@index([operatorId])
  @@map("DepartmentHealth")
}

// ─── Worker Job Queue ─────────────────────────────────────

model WorkerJob {
  id          String    @id @default(cuid())
  jobType     String // reason_situation, evaluate_content, reassess_workstream, score_plan, ...
  operatorId  String
  payload     Json
  status      String    @default("pending") // pending, running, completed, failed
  error       String?
  createdAt   DateTime  @default(now())
  claimedAt   DateTime?
  completedAt DateTime?

  correlationId String?

  @@index([status, createdAt])
  @@index([correlationId, status])
}

model SituationCycle {
  id              String    @id @default(cuid())
  situationId     String
  cycleNumber     Int
  triggerType     String // "detection", "response_received", "timeout", "manual", "signal"
  triggerSummary  String // Human-readable: "No response after 3 days", "Reply received from accounting@nygade.dk"
  cycleSummary    String? // Haiku-generated plain-language summary of what happened in this cycle
  triggerData     Json? // Raw trigger context (email content, signal data, etc.)
  reasoning       Json? // The reasoning output JSON for this cycle
  executionPlanId String?   @unique
  status          String    @default("active") // "active", "completed", "superseded"
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  situation     Situation      @relation(fields: [situationId], references: [id], onDelete: Cascade)
  executionPlan ExecutionPlan? @relation(fields: [executionPlanId], references: [id])

  @@index([situationId, cycleNumber])
  @@index([situationId, status])
}

model ToolCallTrace {
  id            String   @id @default(cuid())
  situationId   String
  cycleNumber   Int      @default(1)
  callIndex     Int // Sequential index within this reasoning session (0-based)
  toolName      String // e.g., "lookup_entity", "search_communications"
  arguments     Json // The arguments the model passed
  resultSummary String? // First 500 chars of result for quick scanning
  resultTokens  Int // Estimated token count of result
  durationMs    Int // How long the tool call took to execute
  createdAt     DateTime @default(now())

  situation Situation @relation(fields: [situationId], references: [id], onDelete: Cascade)

  @@index([situationId])
  @@index([toolName])
}

model EvaluationLog {
  id                  String   @id @default(cuid())
  operatorId          String
  actorEntityId       String? // The person evaluated as needing to act (null if no actor resolved)
  sourceType          String // "email" | "slack_message" | "teams_message"
  sourceId            String // External message ID
  classification      String // "action_required" | "awareness" | "irrelevant"
  awarenessType       String? // "informational" | "strategic" (only for awareness classification)
  summary             String? // LLM-generated summary of the item
  reasoning           String? // Why the LLM classified it this way
  urgency             String? // "low" | "medium" | "high" (null for irrelevant)
  confidence          Float? // 0.0-1.0
  archetypeSlug       String? // Archetype classification from content detection
  archetypeConfidence Float? // 0.0-1.0 confidence of the classification
  situationId         String? // If promoted to a situation, link it here
  metadata            Json? // Original message metadata (from, to, subject, date)
  evaluatedAt         DateTime @default(now())

  @@index([operatorId, evaluatedAt])
  @@index([operatorId, classification])
  @@index([operatorId, actorEntityId])
  @@index([operatorId, sourceId])
}

model FoundationalDocStatus {
  id             String   @id @default(cuid())
  operatorId     String
  docSlug        String
  status         String // "found" | "missing_relevant" | "missing_irrelevant" | "dismissed"
  contentChunkId String? // If found, links to the chunk
  reason         String? // LLM-generated reason for missing_relevant
  dismissedById  String? // If admin dismissed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([operatorId, docSlug])
  @@index([operatorId, status])
}

// ─── Projects ───────────────────────────────────────────

model ProjectTemplate {
  id                String   @id @default(cuid())
  operatorId        String?
  archetypeId       String?
  name              String
  description       String
  category          String // financial, legal, consulting, audit, compliance, etc.
  analysisFramework Json // array of section definitions
  dataExpectations  Json // expected connector types
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  operator       Operator?         @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  archetype      ProjectTemplate?  @relation("TemplateArchetype", fields: [archetypeId], references: [id])
  customizations ProjectTemplate[] @relation("TemplateArchetype")
  projects       Project[]

  @@index([operatorId])
  @@index([category])
}

model Project {
  id                String    @id @default(cuid())
  operatorId        String
  templateId        String?
  name              String
  description       String?
  status            String    @default("draft") // draft, active, paused, completed, archived
  isPortfolio       Boolean   @default(false)
  createdById       String
  dueDate           DateTime?
  completedAt       DateTime?
  config            Json      @default("{}")
  knowledgeIndex    Json?
  compilationStatus String? // null | "compiling" | "compiled" | "stale" | "error"
  compiledAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  operator         Operator              @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  template         ProjectTemplate?      @relation(fields: [templateId], references: [id])
  createdBy        User                  @relation("ProjectCreator", fields: [createdById], references: [id])
  members          ProjectMember[]
  deliverables     ProjectDeliverable[]
  messages         ProjectMessage[]
  notifications    ProjectNotification[]
  chatMessages     ProjectChatMessage[]
  connectors       ProjectConnector[]
  sourceConnectors SourceConnector[]
  parentProjectId  String?
  parentProject    Project?              @relation("ProjectHierarchy", fields: [parentProjectId], references: [id], onDelete: SetNull)
  childProjects    Project[]             @relation("ProjectHierarchy")

  sourceInitiative Initiative?
  contentChunks    ContentChunk[]
  documents        InternalDocument[]
  fileUploads      FileUpload[]

  @@index([operatorId, status])
  @@index([createdById])
  @@index([parentProjectId])
}

// ─── File Uploads ───────────────────────────────────────

model FileUpload {
  id              String   @id @default(cuid())
  operatorId      String
  operator        Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  uploadedBy      String? // nullable: user deletion preserves the file
  uploader        User?    @relation("UserFileUploads", fields: [uploadedBy], references: [id], onDelete: SetNull)
  filename        String
  mimeType        String
  sizeBytes       Int
  storageProvider String   @default("local") // "qorpera", "s3", "local", "connector"
  storageKey      String // provider-specific key/path
  status          String   @default("uploaded") // "uploaded", "processing", "ready", "failed"
  chunkCount      Int      @default(0)
  metadata        Json? // extracted metadata: pageCount, language, etc.
  errorMessage    String? // if status = "failed"

  // Document intelligence pipeline
  extractedFullText       String?    // Complete extracted text (stored before chunking)
  documentProfile         Json?      // Layer 2 classification output (DocumentProfile)
  documentUnderstanding   Json?      // Layer 4 comprehension output (DocumentUnderstanding)
  intelligenceStatus      String     @default("pending")
  // "pending" | "classifying" | "comprehending" | "extracting" | "correlating" | "synthesizing" | "complete" | "skipped" | "failed"
  intelligenceError       String?    // Error message if pipeline fails at any stage
  intelligenceCostCents   Int        @default(0)

  createdAt       DateTime @default(now())

  // Associations
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  contentChunks  ContentChunk[]
  sourceDocument SourceDocument?

  @@unique([operatorId, storageProvider, storageKey])
  @@index([operatorId])
  @@index([projectId])
  @@index([operatorId, status])
}

model ProjectMember {
  id           String   @id @default(cuid())
  projectId    String
  userId       String
  role         String   @default("analyst") // owner, reviewer, analyst, viewer
  restrictions Json? // LLM-interpreted access restrictions from natural language input
  addedAt      DateTime @default(now())
  addedById    String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectMemberUser", fields: [userId], references: [id])
  addedBy User    @relation("ProjectMemberAddedBy", fields: [addedById], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectDeliverable {
  id                 String    @id @default(cuid())
  projectId          String
  title              String
  description        String?
  stage              String    @default("intelligence") // intelligence, workboard, deliverable
  generationMode     String    @default("ai_generated") // ai_generated, human_authored, ai_assisted
  content            Json?
  completenessReport Json?
  confidenceLevel    String? // high, medium, low
  riskCount          Int       @default(0)
  templateSectionId  String?
  assignedToId       String?
  acceptedById       String?
  acceptedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo   User?                @relation("DeliverableAssignee", fields: [assignedToId], references: [id])
  acceptedBy   User?                @relation("DeliverableAcceptor", fields: [acceptedById], references: [id])
  messages     ProjectMessage[]
  chatMessages ProjectChatMessage[]

  @@index([projectId, stage])
  @@index([assignedToId])
}

model ProjectMessage {
  id            String   @id @default(cuid())
  projectId     String
  userId        String
  content       String
  threadId      String?
  deliverableId String?
  createdAt     DateTime @default(now())

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id])
  deliverable ProjectDeliverable? @relation(fields: [deliverableId], references: [id])

  @@index([projectId, createdAt(sort: Desc)])
  @@index([deliverableId])
}

model ProjectNotification {
  id        String   @id @default(cuid())
  projectId String
  type      String // analysis_complete, data_uploaded, risk_flagged, deliverable_ready, stage_change, deadline_approaching, connector_status
  content   String
  metadata  Json?
  readBy    String[] @default([])
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
}

model ProjectChatMessage {
  id            String   @id @default(cuid())
  projectId     String
  deliverableId String
  role          String // user, assistant
  content       String
  userId        String?
  apiCostCents  Int?
  createdAt     DateTime @default(now())

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverable ProjectDeliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  user        User?              @relation(fields: [userId], references: [id])

  @@index([projectId, deliverableId, createdAt])
}

model ProjectConnector {
  id                String   @id @default(cuid())
  projectId         String
  sourceConnectorId String?
  label             String
  provider          String // google-drive, hubspot, economic, etc.
  status            String   @default("pending") // pending, syncing, synced, error
  syncedItemCount   Int      @default(0)
  createdAt         DateTime @default(now())

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceConnector SourceConnector? @relation(fields: [sourceConnectorId], references: [id])

  @@index([projectId])
}

// ─── Wiki Knowledge ─────────────────────────────────────

model KnowledgePage {
  id         String  @id @default(cuid())
  operatorId String?
  projectId  String?
  scope      String  @default("operator") // "operator" | "system"

  // Identity
  pageType        String // OPERATOR: entity_profile, relationship_map, process_description,
  //   financial_pattern, communication_pattern, situation_pattern,
  //   domain_overview, topic_synthesis, operational_learning,
  //   contradiction_log, index, log
  // SYSTEM: fundamentals, methodology, practices, statistics,
  //   theory, ontology_index
  subjectEntityId String?
  domainIds       String[] @default([]) @map("departmentIds")
  title           String
  slug            String

  // Content
  content         String
  contentTokens   Int      @default(0)
  crossReferences String[] @default([])

  // Provenance
  sources     Json     @default("[]")
  sourceCount Int      @default(0)
  sourceTypes String[] @default([])

  // Verification lifecycle
  status           String    @default("draft") // draft | verified | stale | quarantined
  verifiedAt       DateTime?
  verifiedByModel  String?
  verificationLog  Json?
  quarantineReason String?
  staleReason      String?

  // Quality signals
  trustLevel        String @default("provisional") // provisional, established, authoritative, challenged, quarantined
  confidence        Float  @default(0.5)
  reasoningUseCount Int    @default(0)
  outcomeApproved   Int    @default(0)
  outcomeRejected   Int    @default(0)
  citedByPages      Int    @default(0)

  // Synthesis metadata
  version             Int     @default(1)
  synthesisPath       String // "reasoning" | "background" | "onboarding" | "lint"
  synthesizedByModel  String
  synthesisPromptHash String?
  synthesisCostCents  Int?
  synthesisDurationMs Int?
  situationId         String?

  // Timestamps
  lastSynthesizedAt DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Source tracing
  sourceAuthority     String?    // "foundational" | "empirical" | null (operator pages)
  sourceDocumentId    String?    // primary source document
  sourceDocumentIds   String[]   @default([])
  sourceReference     String?    // human-readable: "Financial Shenanigans, Ch. 4, pp. 87-142"
  sourceReferences    Json?      // array of { sourceDocumentId, sectionId, reference, claimSummary, authority }
  stagingStatus       String?    // "staged" | "approved" | "rejected" | "merged"
  stagingReviewedAt   DateTime?
  stagingReviewNote   String?
  lastIntegrityCheck  DateTime?
  integrityStatus     String?    // "verified" | "drift_suspected" | "needs_update"

  // Embedding for search_wiki
  embedding Unsupported("vector(1536)")?

  operator       Operator?              @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  sourceDocument SourceDocument?        @relation(fields: [sourceDocumentId], references: [id])
  versions       KnowledgePageVersion[]
  bookmarks      WikiBookmark[]

  @@unique([operatorId, slug])
  @@unique([operatorId, projectId, subjectEntityId, pageType])
  @@index([operatorId, status])
  @@index([operatorId, pageType])
  @@index([operatorId, projectId])
  @@index([subjectEntityId])
  @@index([scope, pageType])
}

// ─── Wiki Page Versioning ───────────────────────────────

model KnowledgePageVersion {
  id            String        @id @default(cuid())
  pageId        String
  page          KnowledgePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  versionNumber Int
  content       String // full content snapshot at this version
  confidence    Float
  status        String // status at time of version creation
  sourceCount   Int // sourceCount at time of version
  changeReason  String // "synthesis", "human_edit", "answer_integration", "reflection", "adversarial_challenge", "rollback", "merge"
  changedBy     String // model name (e.g. "claude-opus-4-6") or userId
  metadata      Json? // optional: diff summary, evidence IDs cited, etc.
  createdAt     DateTime      @default(now())

  @@unique([pageId, versionNumber])
  @@index([pageId])
}

// ─── Wiki Bookmarks ────────────────────────────────────

model WikiBookmark {
  id         String @id @default(cuid())
  operatorId String
  pageId     String // The wiki page that triggered this bookmark
  pageSlug   String // Denormalized for quick grouping

  // What the librarian noticed
  bookmarkType String // active_engagement, risk, contradiction, opportunity, notable_pattern, active_project, unresolved_question
  reason       String // Free text: why this caught the librarian's eye
  confidence   Float   @default(0.5)
  subjectHint  String? // Entity name or topic the bookmark is about (for grouping)
  metadata     Json    @default("{}")

  // Resolution
  resolved             Boolean     @default(false)
  resolvedAt           DateTime?
  resolvedAction       String? // "initiative_created", "dismissed", "merged"
  resolvedInitiativeId String?
  resolvedInitiative   Initiative? @relation(fields: [resolvedInitiativeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  operator Operator      @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  page     KnowledgePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([operatorId, resolved])
  @@index([operatorId, bookmarkType])
  @@index([pageId])
}

model ResearchPlan {
  id                       String   @id @default(cuid())
  operatorId               String
  investigations           Json // Array<Investigation>
  priorityOrder            Json // string[]
  planningReasoning        String?
  estimatedDurationMinutes Int?
  estimatedCostCents       Int?
  actualCostCents          Int?
  status                   String   @default("planned") // planned, executing, completed, failed
  progressMessage          String?
  completedCount           Int      @default(0)
  failedCount              Int      @default(0)
  totalWikiPages           Int      @default(0)
  adversarialReport        Json?
  gapAnalysisReport        Json?
  questionsForHuman        Json?    // Array<{ question, context, importance, relatedPageSlugs }>
  coverageScore            Float?
  createdAt                DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
}

// ─── Context Evaluation Telemetry ───────────────────────

model ContextEvaluation {
  id            String    @id @default(cuid())
  operatorId    String
  situationId   String

  contextSections Json   // Array<{ type, id, slug?, pageType?, tokenCount }>
  citedSections   Json   // Array<{ type, id, citationCount }>

  outcome    String?   // "approved" | "rejected" | "dismissed"
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  operator  Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  situation Situation @relation(fields: [situationId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([situationId])
}

// ─── System Intelligence Signals ────────────────────────────

model SystemIntelligenceSignal {
  id                String    @id @default(cuid())
  operatorId        String    // which operator generated this signal
  signalType        String    // positive_citation, negative_citation, correction_signal,
                              // gap_signal, pattern_discovery, contradiction_signal,
                              // confirmation_signal, cross_domain_citation
  systemPageSlug    String?   // which system wiki page was involved (null for gap_signal)
  systemPageTitle   String?   // title snapshot at time of signal
  situationTypeSlug String?   // situation type context
  industryVertical  String?   // operator's industry (for aggregation)
  payload           Json      // signal-specific data (search query for gaps, correction details, etc.)

  createdAt         DateTime  @default(now())
  processedAt       DateTime? // when the curator evaluated this
  curatorAction     String?   // update_page, ignore, flag_for_review, queue_research

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([signalType])
  @@index([systemPageSlug])
  @@index([operatorId])
  @@index([createdAt])
  @@index([processedAt])
}

// ─── System Intelligence Change Log ─────────────────────────

// ─── Source Library ─────────────────────────────────────

model SourceDocument {
  id              String   @id @default(cuid())

  // Identity
  title           String
  authors         String?
  domain          String?
  domains         String[]

  // Classification
  sourceType      String   // "book" | "research" | "expert_doc" | "standard" | "empirical_aggregate" | "outcome_analysis" | "regulation"
  sourceAuthority String   // "foundational" | "empirical"

  // Storage
  fileUploadId    String?  @unique
  rawText         String?
  rawMarkdown     String?

  // Processing state
  status          String   @default("uploaded") // uploaded | extracting | synthesizing | staged | complete
  sectionCount    Int?
  pagesProduced   Int      @default(0)
  errorMessage    String?

  // Metadata
  publicationYear Int?
  isbn            String?
  version         String?
  supersededById  String?
  notes           String?

  // Integrity
  lastIntegrityCheck  DateTime?
  integrityStatus     String?   // "healthy" | "drift_detected" | "gaps_found" | "stale"
  integrityNotes      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  sections        SourceSection[]
  integrityChecks IntegrityCheck[]
  knowledgePages  KnowledgePage[]
  fileUpload      FileUpload?      @relation(fields: [fileUploadId], references: [id])
  supersededBy    SourceDocument?   @relation("Supersession", fields: [supersededById], references: [id])
  supersedes      SourceDocument[]  @relation("Supersession")

  @@index([sourceType])
  @@index([sourceAuthority])
  @@index([status])
  @@index([domain])
  @@index([integrityStatus])
}

model SourceSection {
  id              String   @id @default(cuid())
  sourceId        String

  sectionIndex    Int
  title           String
  titleHierarchy  String[]
  content         String
  tokenCount      Int
  pageRange       String?
  sectionType     String   @default("content") // "content" | "preface" | "appendix" | "index" | "case_study" | "framework" | "data_table"

  status          String   @default("pending") // pending | synthesizing | complete | skipped
  pagesProduced   Int      @default(0)
  skipReason      String?
  contentHash     String

  source          SourceDocument @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, sectionIndex])
  @@index([sourceId])
  @@index([contentHash])
}

model IntegrityCheck {
  id              String   @id @default(cuid())
  sourceId        String

  checkType       String   // "coverage" | "accuracy" | "staleness" | "contradiction" | "full"
  status          String   // "healthy" | "drift_detected" | "gaps_found" | "stale" | "contradictions_found"

  findings        Json
  pagesChecked    Int
  issuesFound     Int

  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNotes String?

  modelUsed       String
  tokenCount      Int?
  costCents       Int?

  createdAt       DateTime @default(now())

  source          SourceDocument @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([status])
  @@index([createdAt])
}

model SystemIntelligenceLog {
  id              String   @id @default(cuid())
  action          String   // page_updated, page_created, page_archived, content_pruned, page_split
  pageSlug        String
  pageTitle       String
  pageType        String?  // fundamentals, methodology, theory, practices, statistics, etc.
  previousContent String?  @db.Text // full content before change
  newContent      String?  @db.Text // full content after change
  reason          String   // why the change was made
  changeSource    String   // "research_synthesis", "curator", "admin", "verification"
  signalCount     Int      @default(0) // how many signals drove this decision
  signalSummary   Json?    // aggregated signal data
  operatorCount   Int      @default(0) // how many operators contributed signals (anonymized)
  curatorModel    String?  // which model made the synthesis decision

  createdAt       DateTime @default(now())
  reviewedBy      String?  // superadmin who reviewed
  reviewedAt      DateTime?

  @@index([pageSlug])
  @@index([action])
  @@index([createdAt])
}
